// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0
// 双频趋势共振策略 - TradingView 版本
// 15m 趋势 + 1m 入场（回调/突破 + RSI6 + 布林带 + EMA5/13）

//@version=5
strategy("DualFreq Trend Resonance (TV版)", overlay=true, pyramiding=0, default_qty_type=strategy.cash, default_qty_value=0, initial_capital=10000)

// ========== 参数 ==========
group_tf = "时间周期"
trend_tf = input.timeframe("15", "趋势周期(分钟)", group=group_tf)
entry_tf = input.timeframe("1", "入场周期(分钟)", group=group_tf)

group_15m = "15分钟趋势"
ema9_period = input.int(9, "EMA9", minval=3, maxval=30, group=group_15m)
ema21_period = input.int(21, "EMA21", minval=5, maxval=60, group=group_15m)
trend_relaxed = input.bool(true, "趋势放宽(提高开单)", group=group_15m)
htf_filter = input.bool(true, "高周期趋势过滤(长期稳定)", group=group_15m)
htf2_tf = input.timeframe("60", "高周期(分钟)", group=group_15m)

group_1m = "1分钟入场"
ema5_period = input.int(5, "EMA5", minval=3, maxval=20, group=group_1m)
ema13_period = input.int(13, "EMA13", minval=5, maxval=50, group=group_1m)
rsi_period = input.int(6, "RSI周期", minval=3, maxval=14, group=group_1m)
bb_period = input.int(20, "布林带周期", minval=10, maxval=40, group=group_1m)
bb_std = input.float(2.0, "布林带倍数", minval=1.0, maxval=3.0, group=group_1m)
extreme_vol_pct = input.float(1.0, "5分钟内最大波动%(过滤)", minval=0.2, maxval=5.0, step=0.1, group=group_1m)
use_breakout_mode = input.bool(false, "启用突破入场(更激进)", group=group_1m)
min_bb_width = input.float(0.004, "最小布林带宽度", minval=0.0, maxval=0.05, group=group_1m)
pullback_volume_filter = input.bool(true, "回调量能过滤", tooltip="回调入场需量缩", group=group_1m)
min_entry_gap = input.int(6, "最少间隔K线", minval=1, maxval=100, group=group_1m)
min_atr_pct = input.float(0.0010, "最小波动率(ATR%)", minval=0.0005, maxval=0.01, step=0.0001, group=group_1m)
near_dist_pct = input.float(0.008, "回调靠近EMA/中轨阈值(%)", minval=0.002, maxval=0.03, step=0.001, group=group_1m)
// 额外辅助过滤（默认关闭，打开后提高胜率）
use_macd_filter = input.bool(true, "MACD方向过滤", group=group_1m)
use_rsi_slope = input.bool(true, "RSI斜率过滤", group=group_1m)
use_volume_confirm = input.bool(false, "成交量确认", group=group_1m)
use_htf_rsi = input.bool(false, "高周期RSI过滤", group=group_1m)
htf_rsi_tf = input.timeframe("15", "高周期RSI周期(分钟)", group=group_1m)
htf_rsi_min = input.int(45, "高周期RSI多单下限", minval=30, maxval=60, group=group_1m)
htf_rsi_max = input.int(55, "高周期RSI空单上限", minval=40, maxval=70, group=group_1m)

group_risk = "风险控制"
leverage = input.int(100 ,"杠杆(倍)", minval=1, maxval=200, group=group_risk)
use_fixed_margin = input.bool(true, "固定每单保证金", group=group_risk)
margin_per_trade = input.float(10.0, "每单保证金(U)", minval=1, maxval=1000, group=group_risk)
tp_pct = input.float(150.0, "止盈%(3:1)", minval=1, maxval=300, group=group_risk)
sl_pct = input.float(50.0, "止损%(3:1)", minval=1, maxval=200, group=group_risk)
time_stop_bars = input.int(6, "时间止损(分钟)", minval=1, maxval=30, group=group_risk)
cooldown_bars = input.int(6, "平仓冷却K线", minval=1, maxval=200, group=group_risk)
trend_ema_filter = input.bool(true, "1m均线方向过滤", tooltip="EMA5>EMA13 才做多，反之做空", group=group_risk)
rsi_long_min = input.int(32, "做多RSI下限", minval=20, maxval=50, group=group_risk)
rsi_long_max = input.int(55, "做多RSI上限", minval=40, maxval=70, group=group_risk)
rsi_short_min = input.int(45, "做空RSI下限", minval=30, maxval=70, group=group_risk)
rsi_short_max = input.int(68, "做空RSI上限", minval=50, maxval=85, group=group_risk)
risk_per_trade_pct = input.float(0.5, "单笔风险%", minval=0.1, maxval=5, group=group_risk)
max_pos_pct = input.float(30.0, "最大仓位%", minval=5, maxval=100, group=group_risk)
daily_loss_pct = input.float(5.0, "单日最大回撤%", minval=1, maxval=20, group=group_risk)

group_exit = "出场优化(提升利润因子)"
// 注意：TV 的“交易总数”会把分批止盈(部分平仓)也计入交易，容易让你感觉“开单量变多”
use_partial_tp = input.bool(false, "分批止盈(会增加交易笔数统计)", group=group_exit)
partial_tp_trigger_pct = input.float(80.0, "分批止盈触发%(保证金收益)", minval=1, maxval=300, step=1, group=group_exit)
partial_tp_qty_pct = input.float(50.0, "分批止盈仓位%", minval=1, maxval=99, step=1, group=group_exit)
move_sl_to_be = input.bool(true, "盈利后移动止损到保本", group=group_exit)
be_trigger_pct = input.float(60.0, "保本触发%(保证金收益)", minval=1, maxval=300, step=1, group=group_exit)
use_trailing_close = input.bool(false, "追踪回撤止盈(用close实现)", group=group_exit)
trail_trigger_pct = input.float(120.0, "追踪触发%(保证金收益)", minval=1, maxval=500, step=1, group=group_exit)
trail_retrace_pct = input.float(45.0, "从峰值回撤%触发平仓", minval=5, maxval=95, step=1, group=group_exit)

group_score = "评分/分挡位下单"
use_weighted_positioning = input.bool(true, "启用加权评分分挡位下单", group=group_score)
min_weighted_score = input.float(3.0, "最低加权分(低于不下单)", minval=0.0, maxval=20.0, step=0.1, group=group_score)
score_t1 = input.float(3.0, "挡位1阈值", minval=0.0, maxval=20.0, step=0.1, group=group_score)
score_t2 = input.float(4.5, "挡位2阈值", minval=0.0, maxval=20.0, step=0.1, group=group_score)
score_t3 = input.float(6.0, "挡位3阈值", minval=0.0, maxval=20.0, step=0.1, group=group_score)
score_t4 = input.float(7.5, "挡位4阈值", minval=0.0, maxval=20.0, step=0.1, group=group_score)
margin_t1 = input.float(5.0, "挡位1保证金(U)", minval=0.0, maxval=1000, group=group_score)
margin_t2 = input.float(8.0, "挡位2保证金(U)", minval=0.0, maxval=1000, group=group_score)
margin_t3 = input.float(12.0, "挡位3保证金(U)", minval=0.0, maxval=1000, group=group_score)
margin_t4 = input.float(15.0, "挡位4保证金(U)", minval=0.0, maxval=1000, group=group_score)

// 指标权重（参考 comprehensive.py，可调）
w_trend = input.float(1.5, "趋势权重", minval=0, maxval=5, step=0.1, group=group_score)
w_price_pos = input.float(1.2, "价格位置权重", minval=0, maxval=5, step=0.1, group=group_score)
w_rsi = input.float(1.0, "RSI权重", minval=0, maxval=5, step=0.1, group=group_score)
w_ma = input.float(0.9, "均线状态权重", minval=0, maxval=5, step=0.1, group=group_score)
w_macd = input.float(0.8, "MACD权重", minval=0, maxval=5, step=0.1, group=group_score)
w_vol = input.float(0.7, "量能权重", minval=0, maxval=5, step=0.1, group=group_score)
w_volatility = input.float(0.6, "波动率权重", minval=0, maxval=5, step=0.1, group=group_score)
w_pattern = input.float(0.8, "形态权重(回调/突破)", minval=0, maxval=5, step=0.1, group=group_score)
show_score_debug = input.bool(false, "显示评分调试标签", group=group_score)

group_filters = "额外过滤(减少回撤/提胜率)"
use_adx_filter = input.bool(true, "15m ADX趋势强度过滤", group=group_filters)
adx_len = input.int(14, "ADX周期", minval=5, maxval=50, group=group_filters)
adx_threshold = input.float(20.0, "ADX阈值(越高越少单)", minval=5, maxval=50, step=0.5, group=group_filters)
use_dmi_dir_filter = input.bool(true, "15m DMI方向过滤(+DI/-DI)", group=group_filters)
max_atr_pct = input.float(0.0060, "最大波动率(ATR%)", minval=0.001, maxval=0.05, step=0.0001, group=group_filters)
pos_long_max = input.float(0.85, "多单区间位置上限(越低越不追高)", minval=0.5, maxval=0.99, step=0.01, group=group_filters)
pos_short_min = input.float(0.15, "空单区间位置下限(越高越不抄底)", minval=0.01, maxval=0.5, step=0.01, group=group_filters)

// ========== 15m 趋势（在高周期上计算） ==========
ema9_htf = request.security(syminfo.tickerid, trend_tf, ta.ema(close, ema9_period))
ema21_htf = request.security(syminfo.tickerid, trend_tf, ta.ema(close, ema21_period))
close_htf = request.security(syminfo.tickerid, trend_tf, close)
gap_htf = (ema9_htf - ema21_htf) / ema21_htf
prev_gap_htf = (ema9_htf[1] - ema21_htf[1]) / ema21_htf[1]
trend_state = gap_htf > 0.001 and close_htf > ema21_htf * 1.001 and prev_gap_htf > 0.0005 ? 1 :
     gap_htf < -0.001 and close_htf < ema21_htf * 0.999 and prev_gap_htf < -0.0005 ? -1 : 0
trend_state := trend_relaxed ? (ema9_htf >= ema21_htf ? 1 : -1) : trend_state

is_uptrend = trend_state == 1
is_downtrend = trend_state == -1

// ADX / DMI（15m）
[pdi_htf, mdi_htf, adx_htf] = request.security(syminfo.tickerid, trend_tf, ta.dmi(adx_len, adx_len))
adx_ok = not use_adx_filter or adx_htf >= adx_threshold
dmi_long_ok = not use_dmi_dir_filter or pdi_htf > mdi_htf
dmi_short_ok = not use_dmi_dir_filter or mdi_htf > pdi_htf

// 高周期趋势（用于长期稳定）
ema9_htf2 = request.security(syminfo.tickerid, htf2_tf, ta.ema(close, ema9_period))
ema21_htf2 = request.security(syminfo.tickerid, htf2_tf, ta.ema(close, ema21_period))
htf2_up = ema9_htf2 >= ema21_htf2
htf2_down = ema9_htf2 < ema21_htf2

// ========== 1m 指标 ==========
ema5 = ta.ema(close, ema5_period)
ema13 = ta.ema(close, ema13_period)
rsi = ta.rsi(close, rsi_period)
[macd_line, signal_line, macd_hist] = ta.macd(close, 12, 26, 9)
atr_pct = ta.atr(14) / close

bb_mid = ta.sma(close, bb_period)
bb_std_val = ta.stdev(close, bb_period)
bb_upper = bb_mid + bb_std * bb_std_val
bb_lower = bb_mid - bb_std * bb_std_val
bb_width = (bb_upper - bb_lower) / math.max(bb_mid, 0.0001)

vol_ma5 = ta.sma(volume, 5)
vol_confirm = volume > vol_ma5
rsi_slope_ok_long = rsi > rsi[1]
rsi_slope_ok_short = rsi < rsi[1]
macd_dir_long = macd_hist > 0
macd_dir_short = macd_hist < 0
htf_rsi = request.security(syminfo.tickerid, htf_rsi_tf, ta.rsi(close, 14))
htf_rsi_ok_long = htf_rsi >= htf_rsi_min
htf_rsi_ok_short = htf_rsi <= htf_rsi_max
range_pct_5m = request.security(syminfo.tickerid, "5", (high - low) / close)
extreme_vol_ok = range_pct_5m < (extreme_vol_pct / 100)

// 20根区间位置
high20 = ta.highest(high, 20)
low20 = ta.lowest(low, 20)
pos_in_range = high20 > low20 ? (close - low20) / (high20 - low20) : 0.5
not_at_top = pos_in_range < pos_long_max
not_at_bottom = pos_in_range > pos_short_min

// ========== 回调入场 ==========
near_ema = math.abs(close - ema13) / ema13 < near_dist_pct
near_bb = math.abs(close - bb_mid) / bb_mid < near_dist_pct

rsi_prev = rsi[1]
rsi_prev2 = rsi[2]

vol_pullback_ok = not pullback_volume_filter or (volume < vol_ma5)
prev_closed_down = close[1] < open[1]
prev_closed_up = close[1] > open[1]
long_pullback = (near_ema or near_bb) and prev_closed_down and (rsi > rsi_prev and rsi >= rsi_long_min and rsi <= rsi_long_max) and not_at_top and vol_pullback_ok
short_pullback = (near_ema or near_bb) and prev_closed_up and (rsi < rsi_prev and rsi >= rsi_short_min and rsi <= rsi_short_max) and not_at_bottom and vol_pullback_ok

// ========== 突破入场 ==========
golden_cross = ema5[1] <= ema13[1] and ema5 > ema13
death_cross = ema5[1] >= ema13[1] and ema5 < ema13

long_breakout = close >= bb_upper * 0.998 and golden_cross and rsi > 55 and volume > vol_ma5 * 1.2
short_breakout = close <= bb_lower * 1.002 and death_cross and rsi < 45 and volume > vol_ma5 * 1.2

ema_dir_long = not trend_ema_filter or ema5 > ema13
ema_dir_short = not trend_ema_filter or ema5 < ema13
bb_ok = bb_width >= min_bb_width
volatility_ok = atr_pct >= min_atr_pct and atr_pct <= max_atr_pct
extra_long_ok = (not use_macd_filter or macd_dir_long) and (not use_rsi_slope or rsi_slope_ok_long) and (not use_volume_confirm or vol_confirm) and (not use_htf_rsi or htf_rsi_ok_long)
extra_short_ok = (not use_macd_filter or macd_dir_short) and (not use_rsi_slope or rsi_slope_ok_short) and (not use_volume_confirm or vol_confirm) and (not use_htf_rsi or htf_rsi_ok_short)
long_entry = adx_ok and dmi_long_ok and is_uptrend and ema_dir_long and bb_ok and volatility_ok and extra_long_ok and (not htf_filter or htf2_up) and (long_pullback or (use_breakout_mode and long_breakout))
short_entry = adx_ok and dmi_short_ok and is_downtrend and ema_dir_short and bb_ok and volatility_ok and extra_short_ok and (not htf_filter or htf2_down) and (short_pullback or (use_breakout_mode and short_breakout))

f_score_margin(_score) =>
    float m = 0.0
    m := _score >= score_t4 ? margin_t4 : _score >= score_t3 ? margin_t3 : _score >= score_t2 ? margin_t2 : _score >= score_t1 ? margin_t1 : 0.0
    m

f_weighted_score(_is_long) =>
    float sc = 0.0
    // 1) 趋势对齐
    sc += (_is_long ? is_uptrend : is_downtrend) ? w_trend : 0.0
    // 2) 形态（回调/突破）
    bool pb = _is_long ? long_pullback : short_pullback
    bool bo = _is_long ? (use_breakout_mode and long_breakout) : (use_breakout_mode and short_breakout)
    sc += (pb or bo) ? w_pattern : 0.0
    // 3) 价格位置
    float pos_sc = 0.0
    pos_sc := (near_ema or near_bb) ? math.max(pos_sc, 0.7) : pos_sc
    pos_sc := (_is_long and close <= bb_lower * 1.01) ? math.max(pos_sc, 1.0) : pos_sc
    pos_sc := (not _is_long and close >= bb_upper * 0.99) ? math.max(pos_sc, 1.0) : pos_sc
    sc += pos_sc * w_price_pos
    // 4) RSI 信号
    float rsi_sc = 0.0
    rsi_sc := (_is_long and rsi > rsi[1] and rsi >= rsi_long_min and rsi <= rsi_long_max) ? math.max(rsi_sc, 0.9) : rsi_sc
    rsi_sc := (not _is_long and rsi < rsi[1] and rsi >= rsi_short_min and rsi <= rsi_short_max) ? math.max(rsi_sc, 0.9) : rsi_sc
    sc += rsi_sc * w_rsi
    // 5) 均线状态/交叉
    float ma_sc = 0.0
    ma_sc := (_is_long and ema5 > ema13) ? math.max(ma_sc, 0.6) : ma_sc
    ma_sc := (not _is_long and ema5 < ema13) ? math.max(ma_sc, 0.6) : ma_sc
    ma_sc := (_is_long and bo and golden_cross) ? math.max(ma_sc, 1.0) : ma_sc
    ma_sc := (not _is_long and bo and death_cross) ? math.max(ma_sc, 1.0) : ma_sc
    sc += ma_sc * w_ma
    // 6) MACD
    float macd_sc = 0.0
    macd_sc := (_is_long and macd_hist > 0) ? math.max(macd_sc, 0.7) : macd_sc
    macd_sc := (not _is_long and macd_hist < 0) ? math.max(macd_sc, 0.7) : macd_sc
    macd_sc := (_is_long and macd_hist > macd_hist[1]) ? math.max(macd_sc, 0.9) : macd_sc
    macd_sc := (not _is_long and macd_hist < macd_hist[1]) ? math.max(macd_sc, 0.9) : macd_sc
    sc += macd_sc * w_macd
    // 7) 量能（回调缩量/突破放量）
    float vol_sc = 0.0
    vol_sc := (pb and volume < vol_ma5) ? math.max(vol_sc, 0.7) : vol_sc
    vol_sc := (bo and volume > vol_ma5 * 1.2) ? math.max(vol_sc, 0.9) : vol_sc
    sc += vol_sc * w_vol
    // 8) 波动率（只加分，避免横盘）
    float vt_sc = 0.0
    vt_sc := (bb_width >= min_bb_width) ? math.max(vt_sc, 0.6) : vt_sc
    vt_sc := (atr_pct >= min_atr_pct) ? math.max(vt_sc, 0.6) : vt_sc
    sc += vt_sc * w_volatility
    sc

long_score = f_weighted_score(true)
short_score = f_weighted_score(false)
long_margin_tier = f_score_margin(long_score)
short_margin_tier = f_score_margin(short_score)

// ========== 冷却/时间止损 ==========
var int last_exit_bar = -999
in_cooldown = bar_index - last_exit_bar < cooldown_bars
var int last_entry_bar = -999
entry_spacing_ok = bar_index - last_entry_bar >= min_entry_gap

// 日内风控：单日最大回撤
var float day_start_equity = na
if na(day_start_equity) or dayofmonth != dayofmonth[1]
    day_start_equity := strategy.equity
trade_allowed = strategy.equity >= day_start_equity * (1 - daily_loss_pct / 100)

var int entry_bar = na
in_long = strategy.position_size > 0
in_short = strategy.position_size < 0

// 当前保证金收益率%（用于保本/追踪/分批止盈）
cur_profit_pct = in_long ? (close - strategy.position_avg_price) / strategy.position_avg_price * leverage * 100 :
     in_short ? (strategy.position_avg_price - close) / strategy.position_avg_price * leverage * 100 : 0.0
var float peak_profit_pct = 0.0
if not in_long and not in_short
    peak_profit_pct := 0.0
else
    peak_profit_pct := math.max(peak_profit_pct, cur_profit_pct)

// ========== 入场 ==========
if not in_cooldown and entry_spacing_ok and trade_allowed and extreme_vol_ok and not in_long and not in_short
    if long_entry and (not use_weighted_positioning or long_score >= min_weighted_score)
        tp_price_move = (tp_pct / 100) / leverage
        sl_price_move = (sl_pct / 100) / leverage
        sl_price_move := math.max(sl_price_move, 0.0001)
        risk_amount = strategy.equity * (risk_per_trade_pct / 100)
        qty_risk = risk_amount / (close * sl_price_move)
        qty_cap = (strategy.equity * (max_pos_pct / 100)) / close
        use_margin = use_weighted_positioning ? long_margin_tier : margin_per_trade
        qty_fixed = (use_margin * leverage) / close
        qty = math.abs(use_fixed_margin ? math.min(qty_fixed, qty_cap) : math.min(qty_risk, qty_cap))
        strategy.entry("Long", strategy.long, qty=qty, comment="多头入场")
        entry_bar := bar_index
        last_entry_bar := bar_index
    if short_entry and (not use_weighted_positioning or short_score >= min_weighted_score)
        tp_price_move = (tp_pct / 100) / leverage
        sl_price_move = (sl_pct / 100) / leverage
        sl_price_move := math.max(sl_price_move, 0.0001)
        risk_amount = strategy.equity * (risk_per_trade_pct / 100)
        qty_risk = risk_amount / (close * sl_price_move)
        qty_cap = (strategy.equity * (max_pos_pct / 100)) / close
        use_margin = use_weighted_positioning ? short_margin_tier : margin_per_trade
        qty_fixed = (use_margin * leverage) / close
        qty = math.abs(use_fixed_margin ? math.min(qty_fixed, qty_cap) : math.min(qty_risk, qty_cap))
        strategy.entry("Short", strategy.short, qty=qty, comment="空头入场")
        entry_bar := bar_index
        last_entry_bar := bar_index

// 调试标签（可选）
if show_score_debug and barstate.islast
    label.new(bar_index, high, "LongScore=" + str.tostring(long_score, "#.00") + " margin=" + str.tostring(long_margin_tier, "#.0") + "\nShortScore=" + str.tostring(short_score, "#.00") + " margin=" + str.tostring(short_margin_tier, "#.0"), style=label.style_label_down, textcolor=color.white, color=color.new(color.black, 65))

// ========== 止盈止损（按杠杆后的收益目标换算为价格） ==========
// 例如 100x，止盈100% => 价格只需波动 1%
tp_price_move = (tp_pct / 100) / leverage
sl_price_move = (sl_pct / 100) / leverage
if in_long
    // 保本：达到阈值后，把止损上移到开仓价
    long_stop = strategy.position_avg_price * (1 - sl_price_move)
    long_stop := (move_sl_to_be and cur_profit_pct >= be_trigger_pct) ? math.max(long_stop, strategy.position_avg_price) : long_stop
    // 分批止盈：先平一部分，剩余仓位走主止盈止损
    if use_partial_tp
        tp1_move = (partial_tp_trigger_pct / 100) / leverage
        strategy.exit("Long TP1", "Long", limit=strategy.position_avg_price * (1 + tp1_move), qty_percent=partial_tp_qty_pct)
    strategy.exit("Long TP/SL", "Long", limit=strategy.position_avg_price * (1 + tp_price_move), stop=long_stop)
if in_short
    short_stop = strategy.position_avg_price * (1 + sl_price_move)
    short_stop := (move_sl_to_be and cur_profit_pct >= be_trigger_pct) ? math.min(short_stop, strategy.position_avg_price) : short_stop
    if use_partial_tp
        tp1_move = (partial_tp_trigger_pct / 100) / leverage
        strategy.exit("Short TP1", "Short", limit=strategy.position_avg_price * (1 - tp1_move), qty_percent=partial_tp_qty_pct)
    strategy.exit("Short TP/SL", "Short", limit=strategy.position_avg_price * (1 - tp_price_move), stop=short_stop)

// 追踪回撤止盈：达到一定盈利后，若从峰值回撤超过阈值就平仓（不依赖挂单，更快锁利润）
trail_hit = use_trailing_close and (in_long or in_short) and peak_profit_pct >= trail_trigger_pct and cur_profit_pct <= peak_profit_pct * (1 - trail_retrace_pct / 100)
if trail_hit
    strategy.close(in_long ? "Long" : "Short", comment="追踪回撤止盈")
    last_exit_bar := bar_index
    entry_bar := na

// 时间止损
if (in_long or in_short) and not na(entry_bar) and (bar_index - entry_bar >= time_stop_bars)
    strategy.close(in_long ? "Long" : "Short", comment="时间止损")
    last_exit_bar := bar_index
    entry_bar := na

// 15m 趋势反转退出
if in_long and is_downtrend and cur_profit_pct < 0
    strategy.close("Long", comment="15m趋势反转")
    last_exit_bar := bar_index
    entry_bar := na

if in_short and is_uptrend and cur_profit_pct < 0
    strategy.close("Short", comment="15m趋势反转")
    last_exit_bar := bar_index
    entry_bar := na

// ========== 画图 ==========
plot(ema5, "EMA5", color=color.new(color.blue, 0))
plot(ema13, "EMA13", color=color.new(color.orange, 0))
plot(bb_upper, "BB上轨", color=color.new(color.gray, 70))
plot(bb_lower, "BB下轨", color=color.new(color.gray, 70))
plotshape(long_entry, "多头信号", shape.triangleup, location.belowbar, color.green, size=size.tiny)
plotshape(short_entry, "空头信号", shape.triangledown, location.abovebar, color.red, size=size.tiny)